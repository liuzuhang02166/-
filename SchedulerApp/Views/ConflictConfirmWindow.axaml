<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        x:Class="SchedulerApp.Views.ConflictConfirmWindow"
        x:DataType="sys:String"
        Width="560"
        Height="300"
        WindowStartupLocation="CenterOwner"
        Title="冲突确认"
        CanResize="False">
  <Border Classes="card" Margin="18">
    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
      <StackPanel Spacing="6">
        <TextBlock Text="检测到时间冲突" FontSize="16" FontWeight="SemiBold" />
        <TextBlock Text="{Binding}" FontSize="12" Foreground="#6B7280" TextWrapping="Wrap" />
      </StackPanel>

      <Border Grid.Row="1"
              CornerRadius="14"
              Background="#F9FAFB"
              BorderBrush="#E5E7EB"
              BorderThickness="1"
              Padding="12"
              Margin="0,14,0,0">
        <StackPanel Spacing="8">
          <TextBlock Text="你可以选择：" FontSize="13" FontWeight="SemiBold" />
          <TextBlock Text="1) 重新修改：返回继续调整时间/老师" FontSize="12" Foreground="#6B7280" />
          <TextBlock Text="2) 强制覆盖：仍保存本次变动，并在导出/课表中标记冲突" FontSize="12" Foreground="#6B7280" />
        </StackPanel>
      </Border>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,14,0,0">
        <Button Name="BackButton" Classes="secondary" Content="重新修改" Padding="16,10" />
        <Button Name="ForceButton" Classes="danger" Content="强制覆盖" Padding="16,10" IsDefault="True" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
