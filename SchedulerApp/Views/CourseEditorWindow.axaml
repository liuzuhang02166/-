<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SchedulerApp.ViewModels"
        xmlns:m="using:SchedulerApp.Models"
        x:Class="SchedulerApp.Views.CourseEditorWindow"
        x:DataType="vm:CourseEditorDialogViewModel"
        Width="860"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Title="{Binding Title}">
  <Border Classes="card" Margin="18" Padding="0">
    <Grid RowDefinitions="Auto,*,Auto">
      <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="14,12">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="2">
            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="基础排课（Master）· 冲突将提示二次确认" FontSize="12" Foreground="#6B7280" />
          </StackPanel>
          <Border Grid.Column="1" CornerRadius="12" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10,6" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Classes="mdl2" Text="&#xE946;" Foreground="#6B7280" />
              <TextBlock Text="Esc 关闭" FontSize="12" Foreground="#6B7280" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <ScrollViewer Grid.Row="1">
        <Grid Margin="14" ColumnDefinitions="*,320" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
          <Border Classes="card" Grid.ColumnSpan="2" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16" Padding="12" BoxShadow="0 0 0 0 #00000000">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <TextBlock Text="编辑内容" FontSize="13" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Error}" Foreground="#FFB4B4" FontSize="12" VerticalAlignment="Center" />
            </Grid>
          </Border>

          <Border Grid.Row="1" Classes="card" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16" Padding="12" BoxShadow="0 0 0 0 #00000000">
            <StackPanel Spacing="10">
              <StackPanel>
                <TextBlock Text="老师" FontSize="12" Foreground="#6B7280" />
                <ComboBox Classes="field" Height="40" ItemsSource="{Binding Teachers}" SelectedItem="{Binding SelectedTeacher, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="m:Teacher">
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
              <StackPanel>
                <TextBlock Text="学员" FontSize="12" Foreground="#6B7280" />
                <TextBox Classes="field" Height="40" Text="{Binding StudentName}" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Grid.Row="1" Grid.Column="1" Classes="card" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16" Padding="12" BoxShadow="0 0 0 0 #00000000">
            <StackPanel Spacing="10">
              <StackPanel>
                <TextBlock Text="教学内容" FontSize="12" Foreground="#6B7280" />
                <TextBox Classes="field" Height="40" Text="{Binding Content}" />
              </StackPanel>
              <StackPanel>
                <TextBlock Text="备注" FontSize="12" Foreground="#6B7280" />
                <TextBox Classes="field" Height="96" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Note}" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Grid.Row="2" Classes="card" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16" Padding="12" BoxShadow="0 0 0 0 #00000000">
            <StackPanel Spacing="10">
              <StackPanel>
                <TextBlock Text="开始日期" FontSize="12" Foreground="#6B7280" />
                <DatePicker Name="StartDatePicker" Classes="field" Height="32" SelectedDate="{Binding StartDate, Mode=TwoWay}" />
              </StackPanel>

              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <CheckBox Content="持续" IsChecked="{Binding IsOngoing, Mode=TwoWay}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Spacing="6">
                  <TextBlock Text="终止日期" FontSize="12" Foreground="#6B7280" />
                  <DatePicker Name="EndDatePicker" Classes="field" Height="32" SelectedDate="{Binding EndDate, Mode=TwoWay}" IsEnabled="{Binding EndDateEnabled}" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <Border Grid.Row="2" Grid.Column="1" Classes="card" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16" Padding="12" BoxShadow="0 0 0 0 #00000000">
            <StackPanel Spacing="10">
              <StackPanel>
                <TextBlock Text="上课星期" FontSize="12" Foreground="#6B7280" />
                <ComboBox Classes="field" Height="32" ItemsSource="{Binding Weekdays}" SelectedItem="{Binding SelectedWeekday, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:WeekdayOption">
                      <TextBlock Text="{Binding Text}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                <StackPanel>
                  <TextBlock Text="开始时间" FontSize="12" Foreground="#6B7280" />
                  <TextBox Classes="field" Height="32" Text="{Binding StartTime}" />
                </StackPanel>
                <TextBlock Text="—" VerticalAlignment="Bottom" Margin="0,0,0,6" Foreground="#6B7280" />
                <StackPanel Grid.Column="2">
                  <TextBlock Text="结束时间" FontSize="12" Foreground="#6B7280" />
                  <TextBox Classes="field" Height="32" Text="{Binding EndTime}" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <Border Grid.Row="3" Grid.ColumnSpan="2" Classes="card" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16" Padding="12" BoxShadow="0 0 0 0 #00000000">
            <StackPanel Spacing="8">
              <TextBlock Text="提示：若开始日期晚于本周同星期，则课程会显示在下一周对应日期。" FontSize="12" Foreground="#6B7280" />
              <TextBlock Text="冲突策略：冲突将提示；后续可扩展“强制覆盖并红边标记”。" FontSize="12" Foreground="#6B7280" />
            </StackPanel>
          </Border>
        </Grid>
      </ScrollViewer>

      <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="14,12">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
          <TextBlock Text="按 Enter 确认保存" Foreground="#6B7280" VerticalAlignment="Center" FontSize="12" />
          <Button Name="CancelButton" Grid.Column="1" Classes="secondary" Content="取消" Padding="16,10" />
          <Button Name="OkButton" Grid.Column="2" Classes="primary" Content="保存" Padding="16,10" IsDefault="True" />
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
