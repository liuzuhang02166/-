<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SchedulerApp.App"
             xmlns:local="using:SchedulerApp"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, Microsoft YaHei UI, sans-serif" />
            <Setter Property="Background" Value="#F7F8FA" />
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#111827" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="BoxShadow" Value="0 14 40 0 #1A000000" />
        </Style>

        <Style Selector="TextBox.field, ComboBox.field, DatePicker.field">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#E5E7EB" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#1D4ED8" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#DC2626" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style Selector="Button.danger:pointerover">
            <Setter Property="Background" Value="#B91C1C" />
        </Style>

        <Style Selector="TextBlock.mdl2">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
        </Style>
    </Application.Styles>
</Application>
